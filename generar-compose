#!/bin/env python


def gen_server(
    name: str,
    image: str,
    entrypoint: str,
    config: str,
    network_name: str,
):
    return (
        f"\n  {name}:"
        f"\n    container_name: {name}"
        f"\n    image: {image}"
        f"\n    entrypoint: {entrypoint}"
        f"\n    environment:"
        f"\n      - PYTHONUNBUFFERED=1"
        f"\n    volumes:"
        f"\n      - {config}"
        f"\n    networks:"
        f"\n      - {network_name}"
    )


def gen_client(
    n: int,
    name_prefix: str,
    image: str,
    entrypoint: str,
    env_file: str,
    config: str,
    network_name: str,
):
    client = f"{name_prefix}{n}"

    return (
        f"\n  {client}:"
        f"\n    container_name: {client}"
        f"\n    image: {image}"
        f"\n    entrypoint: {entrypoint}"
        f"\n    environment:"
        f"\n      - CLI_ID={n}"
        f"\n    env_file:"
        f"\n      - path: {env_file}"
        f"\n    volumes:"
        f"\n      - {config}"
        f"\n    networks:"
        f"\n      - {network_name}"
        f"\n    depends_on:"
        f"\n      - server"
    )


def gen_network(name: str, subnet: str):
    return (
        f"\n  {name}:"
        f"\n    ipam:"
        f"\n      driver: default"
        f"\n      config:"
        f"\n        - subnet: {subnet}"
    )


def gen_compose(
    name: str,
    client_amount: int,
    client_name_prefix: str,
    client_image: str,
    client_entrypoint: str,
    client_env_file: str,
    client_config: str,
    server_name_prefix: str,
    server_image: str,
    server_entrypoint: str,
    server_config: str,
    network_name: str,
    subnet: str,
):
    compose = f"name: {name}\nservices:"

    compose += (
        gen_server(
            server_name_prefix,
            server_image,
            server_entrypoint,
            server_config,
            network_name,
        )
        + "\n"
    )

    for i in range(1, client_amount + 1):
        compose += (
            gen_client(
                i,
                client_name_prefix,
                client_image,
                client_entrypoint,
                client_env_file,
                client_config,
                network_name,
            )
            + "\n"
        )

    compose += "\nnetworks:"
    compose += gen_network(network_name, subnet)

    return compose


def main():
    import sys

    NAME = "tp0"
    CLIENT_NAME_PREFIX = "client"
    CLIENT_IMAGE = "client:latest"
    CLIENT_ENTRYPOINT = "/client"
    CLIENT_ENV_FILE = "./client/bet.env"
    CLIENT_CONFIG = "./client/config.yaml:/config.yaml"

    SERVER_NAME_PREFIX = "server"
    SERVER_IMAGE = "server:latest"
    SERVER_ENTRYPOINT = "python3 /main.py"
    SERVER_CONFIG = "./server/config.ini:/config.ini"

    NETWORK_NAME = "testing_net"
    SUBNET = "172.25.125.0/24"

    args = sys.argv

    if len(args) != 3:
        print(f"Usage:\n{args[0]} <filename> <clients>")
        sys.exit(1)

    filename = args[1]
    client_amount = int(args[2])

    compose = gen_compose(
        NAME,
        client_amount,
        CLIENT_NAME_PREFIX,
        CLIENT_IMAGE,
        CLIENT_ENTRYPOINT,
        CLIENT_ENV_FILE,
        CLIENT_CONFIG,
        SERVER_NAME_PREFIX,
        SERVER_IMAGE,
        SERVER_ENTRYPOINT,
        SERVER_CONFIG,
        NETWORK_NAME,
        SUBNET,
    )

    with open(filename, "w") as f:
        f.write(compose)


if __name__ == "__main__":
    main()
